# --- LLM (Multimodal — Vision + Text, supports Function Calling) ---
OPENAI_API_KEY=your_zhipu_api_key_here
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
OPENAI_MODEL=glm-4.6v-flash

# --- Vision LLM (deprecated: main model handles vision directly) ---
# VISION_MODEL=glm-4.6v-flash
# VISION_API_KEY=  (defaults to OPENAI_API_KEY)
# VISION_BASE_URL=  (defaults to OPENAI_BASE_URL)

# --- Embedding ---
EMBEDDING_PROVIDER=zhipu
EMBEDDING_MODEL=embedding-2
# EMBEDDING_API_KEY=  (defaults to OPENAI_API_KEY)
# EMBEDDING_BASE_URL=  (defaults to OPENAI_BASE_URL)

# --- CLIP ---
CLIP_MODEL_NAME=ViT-B/32
CLIP_DEVICE=cpu

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./chroma_data
TEXT_COLLECTION_NAME=text_collection
IMAGE_COLLECTION_NAME=image_collection

# --- Chunker ---
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP_TOKENS=50

# --- RAG ---
RAG_TOP_K=5
RAG_TOP_M=3

# --- Image Processing ---
IMAGE_MAX_DIMENSION=512
IMAGE_SAVE_DIR=./data/images

# --- Agent (Week 4) ---
AGENT_MAX_STEPS=10
AGENT_DEFAULT_STRATEGY=basic
AGENT_SESSION_DIR=./data/sessions
SEARCH_WEB_QUERY_MAX_LENGTH=200
